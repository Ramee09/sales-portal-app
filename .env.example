# Application
NODE_ENV=development
PORT=3000
APP_NAME=sales-portal
APP_VERSION=1.0.0

# Database
MONGODB_URI=mongodb://mongo:27017/sales-portal
DB_HOST=localhost
DB_PORT=27017
DB_NAME=sales-portal

# JWT
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRE=7d

# Stripe (Payment)
STRIPE_API_KEY=stripe_test_key_here
STRIPE_WEBHOOK_SECRET=webhook_secret_here

# Azure
AZURE_STORAGE_ACCOUNT_NAME=storageaccount
AZURE_STORAGE_ACCOUNT_KEY=key_here
AZURE_CONTAINER_NAME=images

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=app-password

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ORIGIN=*
